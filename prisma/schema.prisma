generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  name      String?
  email     String?  @unique
  passwordHash String?
  emailVerifiedAt DateTime?
  marketingEmails Boolean  @default(false)
  timezone  String   @default("America/New_York")

  photos    DailyPhoto[]
  archivePhotos ArchivePhoto[]
  sessions  Session[]
  authTokens AuthToken[]
}

enum AuthTokenType {
  EMAIL_VERIFICATION
  PASSWORD_RESET
}

model AuthToken {
  id        String        @id
  createdAt DateTime      @default(now())
  expiresAt DateTime
  type      AuthTokenType
  userId    String
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, type])
  @@index([expiresAt])
}

model Session {
  id        String   @id
  createdAt DateTime @default(now())
  expiresAt DateTime
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model Prompt {
  id         String   @id @default(cuid())
  createdAt  DateTime @default(now())
  title      String
  constraint String?
  twist      String?
  tags       String?  // comma-separated for MVP
  active     Boolean  @default(true)

  dailyAssignments DailyPromptAssignment[]
  photos           DailyPhoto[]
  archivePhotos    ArchivePhoto[]
}

model DailyPromptAssignment {
  id       String @id @default(cuid())
  dateKey  String // YYYY-MM-DD in user's timezone
  promptId String
  prompt   Prompt @relation(fields: [promptId], references: [id])

  @@unique([dateKey])
}

model DailyPhoto {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  dateKey   String   // YYYY-MM-DD in user's timezone
  imagePath String
  caption   String?
  mood      String?

  userId   String
  user     User   @relation(fields: [userId], references: [id])

  promptId String?
  prompt   Prompt? @relation(fields: [promptId], references: [id])

  @@unique([userId, dateKey])
}

model ArchivePhoto {
  id            String   @id @default(cuid())
  createdAt     DateTime @default(now())
  promptDateKey String
  imagePath     String
  caption       String?
  mood          String?

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  promptId String
  prompt   Prompt @relation(fields: [promptId], references: [id])

  @@index([userId, createdAt])
}
