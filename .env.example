# Local dev: use any Postgres URL (Neon, Supabase, Docker, etc.)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DB?sslmode=require"

# Create a separate private Vercel Blob store with the PRIVATE_BLOB prefix.
# Vercel adds this automatically when the store is connected to the project.
PRIVATE_BLOB_READ_WRITE_TOKEN="vercel_blob_rw_..."
